# Mapbox access token for the Standard basemap (time-of-day lighting + 3D buildings).
# Create one at https://account.mapbox.com/access-tokens/ and copy to .env:
#   VITE_MAPBOX_TOKEN=pk.xxxxxxxx
VITE_MAPBOX_TOKEN=

# Optional: override the API base (defaults to /api, proxied to :8000 in dev).
# VITE_API_BASE=/api
